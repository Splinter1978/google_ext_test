{
  "manifest_version": 3,
  "name": "AI Assistant (Monica Pro Style)",
  "version": "1.2",
  "description": "Сайдбар ШІ з контекстним меню та швидким виділенням тексту",
  "permissions": [
    "sidePanel",
    "contextMenus",
    "activeTab",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_title": "Відкрити асистента"
  }
}