{
  "manifest_version": 3,
  "name": "AI Search Assistant",
  "version": "1.0",
  "description": "Пошук та ШІ-помічник на базі вбудованого Gemini Nano",
  "permissions": [
    "identity",
    "storage",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": "icon.png"
  },
  "oauth2": {
    "client_id": "ТВІЙ_GOOGLE_CLIENT_ID.apps.googleusercontent.com",
    "scopes": ["https://www.googleapis.com/auth/userinfo.email", "https://www.googleapis.com/auth/userinfo.profile"]
  }
}